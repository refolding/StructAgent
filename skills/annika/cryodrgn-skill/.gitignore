# Local/private environment reports generated by scripts/cryodrgn_env_probe.py.
# These describe a specific host (paths, GPU, versions) and must not be committed,
# uploaded, or shared. Regenerate with the probe instead of editing by hand.
configs/site_config.local.md
configs/site_config.local.json
configs/site_config.local.*

# Any user-pasted/captured environment reports.
configs/*.local.*

# Python bytecode / caches.
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# Editor/OS noise.
.DS_Store
*.swp

# Never ship cryoDRGN data/model artifacts via this skill (defense in depth;
# v0 produces none of these, but guard against accidental inclusion).
*.mrc
*.mrcs
*.star
*.cs
*.pkl
*.pth
